# ============================================================================
# HARAMAYA UNIVERSITY PHARMACY MANAGEMENT SYSTEM
# Frontend Environment Configuration Template
# Copy this file to .env and update the values
# ============================================================================

# API Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Haramaya Pharmacy Management System
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Role-Based Pharmacy Management System

# Development Configuration
VITE_NODE_ENV=development
VITE_DEBUG=true

# Authentication Configuration
VITE_TOKEN_STORAGE_KEY=pharmacy_token
VITE_USER_STORAGE_KEY=pharmacy_user
VITE_SESSION_TIMEOUT=86400000

# UI Configuration
VITE_ITEMS_PER_PAGE=15
VITE_TOAST_DURATION=3000
VITE_THEME=light

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=false
VITE_ENABLE_OFFLINE_MODE=false

# File Upload Configuration
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png

# Reporting Configuration
VITE_DEFAULT_DATE_FORMAT=YYYY-MM-DD
VITE_DEFAULT_CURRENCY=ETB
VITE_TIMEZONE=Africa/Addis_Ababa

# Performance Configuration
VITE_ENABLE_PWA=false
VITE_CACHE_DURATION=300000